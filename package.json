{
  "name": "heirloom-tool",
  "private": true,
  "version": "1.0.0",
  "description": "传家宝 1.0 monorepo",
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "dev:web": "pnpm --filter @heirloom/web dev",
    "dev:api": "pnpm --filter @heirloom/api dev",
    "dev": "pnpm -r --parallel --filter @heirloom/web --filter @heirloom/api dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint"
  }
}
